# ========================================
# Danjjak Backend 환경 변수 설정
# ========================================

# Google Gemini API Key
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# 서버 포트 (기본값: 3000)
PORT=3000

# Gemini 모델 선택 (기본값: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash
